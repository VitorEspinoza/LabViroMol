# .env.ci.example
#
# Valores fake/determinísticos para a stack efêmera de CI
# (docker-compose.ci.yaml — planos 03/13/20). Copiar para `.env.ci` antes de
# usar:
#
#   cp .env.ci.example .env.ci
#   docker compose -f docker-compose.ci.yaml --env-file .env.ci up -d --wait
#
# Nenhum valor aqui é um segredo real — connection string e credenciais do
# Postgres apontam para o serviço efêmero `postgres` deste mesmo compose
# (descartado em `down -v`), e a chave JWT é uma string fixa de ≥32
# caracteres usada apenas dentro da stack de CI/perf, nunca em produção.

JWT_KEY=ci-fake-secret-key-must-be-at-least-32-characters-long
JWT_ISSUER=LabViroMol
JWT_AUDIENCE=LabViroMol
POSTGRES_USER=labviromol_ci
POSTGRES_PASSWORD=labviromol_ci
POSTGRES_DB=LabViroMol_CI
DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=LabViroMol_CI;Username=labviromol_ci;Password=labviromol_ci
