{
  "OpenTelemetry": {
    "Tracing": {
      "SamplingRatio": 0.1
    }
  },
  "LoadTest": {
    "UseNoOpTranslator": false,
    "UseNoOpEmail": true,
    "NpgsqlMaxPoolSize": 20
  },
  "Translation": {
    "IntervalMinutes": 60
  },
  "RateLimiting": {
    "SchedulingPolicy": {
      "PermitLimit": 5,
      "WindowSeconds": 30
    }
  }
}
